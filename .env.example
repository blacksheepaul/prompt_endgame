# Server Configuration
# Address to bind the HTTP server (default: :8080)
SERVER_ADDR=:8080

# Server read timeout as a duration string (e.g., "15s", "30s", "1m")
# Default: 15s
SERVER_READ_TIMEOUT=15s

# Server write timeout as a duration string
# Default: 0 (no timeout, recommended for SSE)
SERVER_WRITE_TIMEOUT=0

# LLM Provider Configuration
# Provider type: "mock" or "openai"
# "openai" is compatible with any OpenAI-format service: FakeLLM, vLLM, Ollama, OpenRouter, etc.
# Default: mock
PROVIDER_TYPE=mock

# Token delay for mock provider (e.g., "50ms", "100ms", "1s")
# Default: 50ms (only used when PROVIDER_TYPE=mock)
PROVIDER_TOKEN_DELAY=50ms

# OpenAI-compatible provider configuration (used when PROVIDER_TYPE=openai)
# Endpoint may be either the base API URL or the full chat completions URL.
# Recommended: use the base API URL.
# Examples:
#   http://localhost:10181/v1
#   https://api.openai.com/v1
PROVIDER_ENDPOINT=http://localhost:10181/v1
# API key — may be left empty for local/unauthenticated services
PROVIDER_API_KEY=
# Model name passed in the request body
# Default: gpt-3.5-turbo
PROVIDER_MODEL=gpt-3.5-turbo

# Scenery Configuration
# Base path for scenery files
# Default: ./sceneries
SCENERY_PATH=./sceneries

# Logging Configuration
# Log level: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Store Configuration
# Store type: "memory" or "sqlite"
# Default: memory
STORE_TYPE=memory

# SQLite database file path (used when STORE_TYPE=sqlite)
# Default: ./data/prompt_endgame.db
STORE_SQLITE_PATH=./data/prompt_endgame.db

# Enable automatic memory offloading for idle rooms (used when STORE_TYPE=sqlite)
# Default: false
STORE_OFFLOAD_ENABLED=false

# Maximum number of rooms to keep in memory when offloading is enabled
# Default: 100
STORE_MAX_CACHED_ROOMS=100

# How long a room must be idle before being offloaded from memory
# Default: 5m
STORE_IDLE_TIMEOUT=5m

# For production use with external LLM providers, you would add:
# PROVIDER_API_KEY=your-openai-key-here
